#!/bin/sh
# Sync root files to skills/dajare/
# Root SKILL.md, scripts/rhyme.py, and references/ are the single source of truth.

cp SKILL.md skills/dajare/SKILL.md
git add skills/dajare/SKILL.md

mkdir -p skills/dajare/scripts
cp scripts/rhyme.py skills/dajare/scripts/rhyme.py
git add skills/dajare/scripts/rhyme.py

if [ -f scripts/rhyme-dict.json.gz ]; then
  cp scripts/rhyme-dict.json.gz skills/dajare/scripts/rhyme-dict.json.gz
  git add skills/dajare/scripts/rhyme-dict.json.gz
fi

mkdir -p skills/dajare/references
rm -f skills/dajare/references/*.md
for f in references/*.md; do
  if [ -f "$f" ]; then
    cp "$f" "skills/dajare/$f"
    git add "skills/dajare/$f"
  fi
done
